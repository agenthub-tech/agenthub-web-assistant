{
  "name": "agenthub-web-assistant",
  "version": "1.0.0",
  "description": "AgentHub Web Assistant - Web embedded assistant built on JS SDK",
  "main": "dist/aa.js",
  "module": "dist/aa.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/aa.esm.js",
      "require": "./dist/aa.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs && npx tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agenthub",
    "web-assistant",
    "ai",
    "assistant",
    "chatbot"
  ],
  "license": "MIT",
  "dependencies": {
    "agenthub-sdk": "git+https://gogsit.sinocare.com/agenthub/agenthub-sdk-js.git",
    "echarts": "^5.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.20.0",
    "events": "^3.3.0",
    "fast-check": "^3.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
